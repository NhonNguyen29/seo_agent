# SEO Agent Pipeline — Configuration Template
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# =====================================================================
# API Keys (Required for full functionality)
# =====================================================================

# Serper.dev API Key — For SERP research (mobile Vietnam locale)
# Get it from: https://serper.dev/
SERPER_API_KEY=YOUR_SERPER_API_KEY

# Firecrawl API Key — For content scraping & cleanup
# Get it from: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=YOUR_FIRECRAWL_API_KEY

# OpenRouter API Key — For LLM-powered outline generation
# Get it from: https://openrouter.ai/
OPENROUTER_API_KEY=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

# =====================================================================
# Logging & Output Configuration
# =====================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Output directory for results (outlines, metadata, etc.)
OUTPUT_DIR=./outputs

# Log directory for pipeline execution logs
LOG_DIR=./logs

# =====================================================================
# Pipeline Tuning Parameters
# =====================================================================

# Research (Pipeline 1)
# Number of competitor URLs to fetch per keyword
RESEARCH_RESULTS_PER_KW=5

# Scraper (Pipeline 2)
# Maximum URLs to scrape per keyword (cost/time optimization)
SCRAPER_MAX_PER_KEYWORD=3

# Request timeout in seconds
SCRAPER_TIMEOUT=30

# Delay between requests (seconds) to avoid rate limiting
SCRAPER_DELAY=1.0

# Filter (Pipeline 3)
# Semantic similarity threshold for deduplication (0.0 to 1.0)
# Lower = more aggressive deduplication
SEMANTIC_SIMILARITY_THRESHOLD=0.75

# Outline (Pipeline 4)
# OpenRouter model for reasoning/structure (change for cost/quality tradeoff)
OUTLINE_MODEL=deepseek/deepseek-r1:free

# Alternative models: 
# - openrouter/auto (cheapest)
# - anthropic/claude-3.5-sonnet (best quality)
# - google/gemini-2.0-flash-thinking-exp-1219

# Maximum context length (tokens) for outline generation
OUTLINE_MAX_TOKENS=2048

# =====================================================================
# Advanced Options
# =====================================================================

# Use proxy for scraping (optional, for enterprise deployments)
# PROXY_URL=http://proxy.example.com:8080

# Enable concurrent requests (async scraping)
# ENABLE_ASYNC=true
# MAX_CONCURRENT_REQUESTS=5

# Cache results between runs (for testing)
# ENABLE_CACHE=true
# CACHE_DIR=./cache

# NLP Language Model
# 'vi_core_news_lg' for Vietnamese, 'en_core_web_lg' for English
NLP_MODEL=vi_core_news_lg
# OpenRouter model for keyword discovery

OPENROUTER_API_KEY=sk-your-real-key
DOMAIN_KEYWORD_MODEL=deepseek/deepseek-r1:free

# Max tokens cho OpenRouter khi phân tích domain
DOMAIN_KEYWORD_MAX_TOKENS=1200

# Số keyword tối đa để gợi ý
DOMAIN_KEYWORD_SUGGESTION_LIMIT=20

# Timeout fetch domain
DOMAIN_FETCH_TIMEOUT=30